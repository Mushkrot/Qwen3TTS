+def ensure_training_speaker_encoder(model, source_model_path):
+    if model.speaker_encoder is not None:
+        return
+
+    local_source_path = (
+        source_model_path
+        if os.path.isdir(source_model_path)
+        else snapshot_download(source_model_path)
+    )
+    weights_path = os.path.join(local_source_path, "model.safetensors")
+    if not os.path.isfile(weights_path):
+        raise FileNotFoundError(
+            f"speaker encoder source has no model.safetensors: {weights_path}"
+        )
+
+    speaker_encoder = Qwen3TTSSpeakerEncoder(model.config.speaker_encoder_config)
+    state_dict = {}
+    with safe_open(weights_path, framework="pt", device="cpu") as handle:
+        for key in handle.keys():
+            if key.startswith("speaker_encoder."):
+                state_dict[key.removeprefix("speaker_encoder.")] = handle.get_tensor(key)
+
+    if not state_dict:
+        raise RuntimeError(
+            f"speaker encoder source has no speaker_encoder weights: {source_model_path}"
+        )
+
+    speaker_encoder.load_state_dict(state_dict, strict=True)
+    speaker_encoder.to(dtype=model.dtype)
+    model.speaker_encoder = speaker_encoder
+
+
